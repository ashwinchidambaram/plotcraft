}

deploy: Deploy {
  shape: oval
  style.font-size: 18
  style.fill: "#E3E8DF"
  style.stroke: "#485240"
  style.font-color: "#2C2C2C"
}

every_step_is_automated,_every: Every step is automated, every gate must pass {
  shape: text
  style.font-size: 14
  style.font-color: "#757575"
}

ann_run_tests_0: Automated CI {
  shape: text
  style.font-size: 13
  style.font-color: "#757575"
}
run_tests -- ann_run_tests_0: {
  style.stroke-dash: 3
  style.opacity: 0.4
}

ann_code_review_1: Manual gate {
  shape: text
  style.font-size: 13
  style.font-color: "#757575"
}
code_review -- ann_code_review_1: {
  style.stroke-dash: 3
  style.opacity: 0.4
}

push_code -> run_tests {
  style.stroke: "#A84F3B"
}
run_tests -> code_review {
  style.stroke: "#853D2D"
}
code_review -> deploy {
  style.stroke: "#757575"
}
